{
  "name": "design-brain-memory",
  "version": "0.9.1",
  "description": "Relational markdown design memory powered by Agent Browser CLI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/design-brain/design-brain.git"
  },
  "homepage": "https://github.com/design-brain/design-brain#readme",
  "bugs": {
    "url": "https://github.com/design-brain/design-brain/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "design-brain-memory": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "test": "npm run build && node --test tests/*.test.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "design",
    "design-system",
    "second-brain",
    "agent-browser",
    "markdown"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "fs-extra": "^11.3.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
